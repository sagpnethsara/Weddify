{
  "name": "weddify",
  "version": "1.0.0",
  "description": "Weddify frontend built with Next.js 14",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "clean:deep": "node -e \"const fs=require('fs'); ['.next','.turbo','node_modules/.cache'].forEach(p=>fs.rmSync(p,{recursive:true,force:true}));\"",
    "dev": "next dev",
    "dev:clean": "npm run clean && next dev",
    "dev:stable": "npm run clean:deep && next dev",
    "build": "next build",
    "build:clean": "npm run clean && next build",
    "start": "next start",
    "lint": "next lint"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.14.0",
    "framer-motion": "^12.38.0",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^1.7.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
